@code {
    [Parameter] public EventCallback OnNavigation { get; set; }

    private bool _isDisposed = false;

    private async Task HandleNavClick()
    {
        if (_isDisposed) return;

        try
        {
            Console.WriteLine("NavMenu HandleNavClick called!");

            // Small delay for visual feedback before closing drawer
            await Task.Delay(50);

            // Notify parent to close drawer on mobile
            if (!_isDisposed && OnNavigation.HasDelegate)
            {
                Console.WriteLine("Calling OnNavigation.InvokeAsync()");
                await OnNavigation.InvokeAsync();
                Console.WriteLine("OnNavigation.InvokeAsync() completed");
            }
        }
        catch (Exception ex)
        {
            if (!_isDisposed)
            {
                Console.WriteLine($"Error in HandleNavClick: {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
    }
}