@code {
    private ProfileResponseDTO? profile;
    private string profileImageUrl = string.Empty;

    private bool isLoading = true;
    private bool isLoadingProfileImage = false;
    private string errorMessage = string.Empty;
    private string imageLoadingStatus = "Not started";
    private int activeTabIndex = 0;
    private bool showDebugInfo = false;
    private bool isMobile = false;

    private int individualTrainingSessions = 21;
    private int teamTrainingSessions = 9;

    private void OnBreakpointChanged(Breakpoint breakpoint)
    {
        isMobile = breakpoint <= Breakpoint.Sm;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        // Check authentication
        if (!await LoginService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            imageLoadingStatus = "Profile loading...";
            StateHasChanged();

            Console.WriteLine("Profile.razor: Loading profile from ProfileService...");
            profile = await ProfileService.GetProfileAsync();

            if (profile == null)
            {
                errorMessage = "Failed to load profile information.";
                imageLoadingStatus = "Profile load failed";
            }
            else
            {
                Console.WriteLine($"Profile.razor: Profile loaded successfully: {profile.MemberFirstName}");
                imageLoadingStatus = "Profile loaded, starting image load...";

                // Load profile image after profile is loaded
                await LoadProfileImage();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Profile.razor: Error loading profile: {ex.Message}");
            errorMessage = "An error occurred while loading your profile.";
            imageLoadingStatus = $"Profile error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadProfileImage()
    {
        try
        {
            if (profile?.MemberGuid == null)
            {
                imageLoadingStatus = "No member GUID available";
                Console.WriteLine("Profile.razor: No member GUID available for image loading");
                return;
            }

            isLoadingProfileImage = true;
            imageLoadingStatus = "Loading image...";
            StateHasChanged();

            Console.WriteLine($"Profile.razor: Loading profile image for: {profile.MemberGuid}");
            var imageUrl = await ProfileService.GetProfileImageUrlAsync();

            if (!string.IsNullOrEmpty(imageUrl))
            {
                profileImageUrl = imageUrl;
                imageLoadingStatus = $"Image loaded: {imageUrl}";
                Console.WriteLine($"Profile.razor: Profile image loaded: {imageUrl}");
                Snackbar.Add("Profile image loaded successfully!", Severity.Success);
            }
            else
            {
                imageLoadingStatus = "No image found - showing initials";
                Console.WriteLine("Profile.razor: No profile image found - will show initials");
            }
        }
        catch (Exception ex)
        {
            imageLoadingStatus = $"Image load error: {ex.Message}";
            Console.WriteLine($"Profile.razor: Error loading profile image: {ex.Message}");
            Snackbar.Add($"Error loading profile image: {ex.Message}", Severity.Warning);
        }
        finally
        {
            isLoadingProfileImage = false;
            StateHasChanged();
        }
    }

    // Image event handlers for debugging
    private void OnImageLoad()
    {
        imageLoadingStatus = "Image displayed successfully";
        Console.WriteLine("Profile.razor: Image loaded and displayed in browser");
        StateHasChanged();
    }

    private void OnImageError()
    {
        imageLoadingStatus = "Image failed to display in browser";
        Console.WriteLine($"Profile.razor: Image failed to load in browser. URL was: {profileImageUrl}");
        Snackbar.Add("Image failed to load in browser", Severity.Error);

        // Reset to show initials instead
        profileImageUrl = string.Empty;
        StateHasChanged();
    }

    // Helper methods for display

    private string GetDisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "Not provided" : value;

    private string GetDisplayName()
    {
        if (profile == null || (string.IsNullOrWhiteSpace(profile.MemberFirstName) && string.IsNullOrWhiteSpace(profile.MemberLastName)))
            return "Ikke angivet";

        var firstName = profile.MemberFirstName?.Trim() ?? "";
        var lastName = profile.MemberLastName?.Trim() ?? "";

        return $"{firstName} {lastName}".Trim();
    }

    private string GetOrganizationStatus()
    {
        if (profile == null) return "Not assigned";

        var hasMainOrg = !string.IsNullOrWhiteSpace(profile.OrganisationMainGuid);
        var hasSubOrg = !string.IsNullOrWhiteSpace(profile.OrganisationSubGuid);

        if (hasMainOrg && hasSubOrg) return "Active Member";
        if (hasMainOrg) return "Active Member";
        if (hasSubOrg) return "Active Member";

        return "Inactive";
    }

    private string GetInitials()
    {
        // Check if we have both first and last name
        if (string.IsNullOrWhiteSpace(profile?.MemberFirstName) || string.IsNullOrWhiteSpace(profile?.MemberLastName))
            return "??";

        var initials = "";

        // Get first initial from first name
        initials += profile.MemberFirstName.Trim()[0].ToString().ToUpper();

        // Handle last name with potential special characters like hyphens and spaces
        var lastNameParts = profile.MemberLastName.Split(new char[] { '-', ' ' }, StringSplitOptions.RemoveEmptyEntries);

        // Get initials from all parts of the last name
        foreach (var part in lastNameParts)
        {
            if (!string.IsNullOrWhiteSpace(part))
            {
                initials += part.Trim()[0].ToString().ToUpper();
            }
        }

        return initials;
    }
}