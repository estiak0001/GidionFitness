@page "/login/forgot-password"

@inject IResetPasswordService ResetPasswordService


<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudCard>
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center justify-center mb-4">
                    <MudIcon Icon="Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                    <MudText Typo="Typo.h4" Color="Color.Primary">Forgot Password</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Class="mb-4">
                Enter your email address below to receive a password reset link.
            </MudText>
            <EditForm Model="@resetPasswordRequest" OnValidSubmit="@HandleForgotPassword">
                <DataAnnotationsValidator />
                <MudTextField @bind-Value="resetPasswordRequest.Email"
                              Label="Email Address"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Required="true"
                              For="@(() => resetPasswordRequest.Email)"
                              HelperText="Enter your registered email address"
                              Adornment="Adornment.Start"
                              AdornmentIcon="Icons.Material.Filled.Email" />
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large">
                    Send Reset Link
                </MudButton>
            </EditForm>
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mt-4">@successMessage</MudAlert>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
            }
        </MudCardContent>
    </MudCard>

</MudContainer>

@code {
    private ForgotPasswordRequestDTO resetPasswordRequest = new();
    
    private string successMessage;
    private string errorMessage;




    private async Task HandleForgotPassword()
    {
        // Simulate sending reset link
        if (string.IsNullOrWhiteSpace(resetPasswordRequest.Email))
        {
            errorMessage = "Email address is required.";
            successMessage = string.Empty;
        }
        else
        {
            var result = await ResetPasswordService.SendEmailAsync(resetPasswordRequest);
            Console.WriteLine($"Reset password result: {result}");
            successMessage = result.Message;
            errorMessage = string.Empty;
        }
    }




}
