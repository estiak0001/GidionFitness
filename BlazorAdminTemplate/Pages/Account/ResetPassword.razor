@page "/reset-password"
@inject IResetPasswordService ResetPasswordService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using System.Web

<PageTitle>Reset Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudCard Elevation="3">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center justify-center mb-4">
                    <MudIcon Icon="Icons.Material.Filled.LockReset" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
                    <MudText Typo="Typo.h4" Color="Color.Primary">Reset Password</MudText>
                </div>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (string.IsNullOrEmpty(resetToken))
            {
                <MudAlert Severity="Severity.Error" ContentAlignment="HorizontalAlignment.Center">
                    Invalid or missing reset token. Please check your email link or request a new password reset.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body1" Class="mb-4" Align="Align.Center">
                    Enter your new password below.
                </MudText>

                <EditForm Model="@resetPasswordRequest" OnValidSubmit="@HandleResetPassword">
                    <DataAnnotationsValidator />
                    <MudStack Spacing="4">
                        <MudTextField @bind-Value="resetPasswordRequest.NewPassword"
                                      Label="New Password"
                                      Variant="Variant.Outlined"
                                      InputType="@(showPassword? InputType.Text: InputType.Password)"
                                      Required="true"
                                      HelperText="Enter your new password (minimum 6 characters)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => showPassword = !showPassword)" />

                        <MudTextField @bind-Value="confirmPassword"
                                      Label="Confirm Password"
                                      Variant="Variant.Outlined"
                                      InputType="@(showConfirmPassword? InputType.Text: InputType.Password)"
                                      Required="true"
                                      HelperText="Confirm your new password"
                                      Error="@(!string.IsNullOrEmpty(confirmPassword) && confirmPassword != resetPasswordRequest.NewPassword)"
                                      ErrorText="Passwords do not match"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(showConfirmPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => showConfirmPassword = !showConfirmPassword)" />

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@isLoading"
                                   Size="Size.Large">
                            @if (isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ml-2">Resetting...</MudText>
                            }
                            else
                            {
                                <MudIcon Icon="Icons.Material.Filled.Lock" Class="mr-2" />
                                <span>Reset Password</span>
                            }
                        </MudButton>

                        @if (!string.IsNullOrEmpty(responseMessage))
                        {
                            <MudAlert Severity="@alertSeverity" ContentAlignment="HorizontalAlignment.Center">
                                @responseMessage
                            </MudAlert>
                        }
                    </MudStack>
                </EditForm>
            }
        </MudCardContent>
        <MudCardActions Class="justify-center pb-4">
            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/login"))">
                Back to Login
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private ResetPasswordRequestDTO resetPasswordRequest = new();
    private string confirmPassword = string.Empty;
    private string resetToken = string.Empty;
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private string responseMessage = string.Empty;
    private Severity alertSeverity = Severity.Info;

    protected override void OnInitialized()
    {
        // Extract token from query parameters using System.Web.HttpUtility
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = uri.Query;

        if (!string.IsNullOrEmpty(query))
        {
            // Parse query string using HttpUtility
            var queryParams = HttpUtility.ParseQueryString(query);
            var token = queryParams["token"];

            if (!string.IsNullOrEmpty(token))
            {
                resetToken = token;
                resetPasswordRequest.Token = resetToken;
                Console.WriteLine($"Reset token: {resetToken}");
            }
            else
            {
                Console.WriteLine("No reset token found in URL");
            }
        }
    }

    private async Task HandleResetPassword()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(resetPasswordRequest.NewPassword))
        {
            responseMessage = "Password is required.";
            alertSeverity = Severity.Warning;
            return;
        }

        if (resetPasswordRequest.NewPassword.Length < 6)
        {
            responseMessage = "Password must be at least 6 characters long.";
            alertSeverity = Severity.Warning;
            return;
        }

        if (resetPasswordRequest.NewPassword != confirmPassword)
        {
            responseMessage = "Passwords do not match.";
            alertSeverity = Severity.Warning;
            return;
        }

        if (string.IsNullOrEmpty(resetToken))
        {
            responseMessage = "Invalid reset token.";
            alertSeverity = Severity.Error;
            return;
        }

        isLoading = true;
        responseMessage = string.Empty;

        try
        {
            var result = await ResetPasswordService.ResetPasswordAsync(resetPasswordRequest);

            if (result != null && !string.IsNullOrEmpty(result.Message))
            {
                responseMessage = result.Message;
                alertSeverity = Severity.Success;

                Snackbar.Add(result.Message, Severity.Success);

                // Redirect to login after successful reset
                await Task.Delay(2000); // Show success message for 2 seconds
                Navigation.NavigateTo("/login");

                Console.WriteLine($"Password reset result: {result.Message}");
            }
            else
            {
                responseMessage = "Password reset failed. Please try again or request a new reset link.";
                alertSeverity = Severity.Error;

                Snackbar.Add("Password reset failed!", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            responseMessage = "An error occurred while resetting your password. Please try again.";
            alertSeverity = Severity.Error;

            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Console.WriteLine($"Password reset error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }
}