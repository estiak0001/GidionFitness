@page "/classes/create-multiple"
@using BlazorAdminTemplate.Application.DTOs.Classes
@using BlazorAdminTemplate.Application.DTOs.Location
@using BlazorAdminTemplate.Application.DTOs.ClassTypes
@using BlazorAdminTemplate.Application.DTOs.Memberships
@inject IStaffManagementService StaffService
@inject IMembershipService MembershipService
@inject ITrainingClassesService TrainingClassesService
@inject ISnackbar Snackbar

<PageTitle>Create Multiple Recurring Classes</PageTitle>

<div class="d-flex justify-center pa-4">
    <div style="max-width: 900px; width: 100%;">
        <MudText Typo="Typo.h4" GutterBottom="true" Class="text-center mb-6">
            Create Multiple Recurring Training Classes
        </MudText>

        <MudPaper Class="pa-8" Elevation="6" Style="border-radius: 16px;">
            <EditForm Model="@dto" OnValidSubmit="SubmitClasses">
                <DataAnnotationsValidator />
                <MudGrid Spacing="4">

                    <!-- Class Type -->
                    <MudItem xs="12">
                        <MudSelect T="string" Label="Class Type" @bind-Value="dto.TrainingClassTypesGUID" Required="true">
                            @foreach (var ct in classTypes)
                            {
                                <MudSelectItem Value="@ct.TrainingClassTypesGUID">
                                    @ct.TrainingClassTypesName (@ct.TrainingClassLocationName)
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <!-- Location -->
                    <MudItem xs="12">
                        <MudSelect T="string" Label="Location" @bind-Value="dto.TrainingClassLocationGUID" Required="true">
                            @foreach (var loc in locations)
                            {
                                <MudSelectItem Value="@loc.TrainingClassLocationGUID">
                                    @loc.TrainingClassLocationName
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <!-- Name -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="dto.TrainingClassClassesName"
                                      Label="Class Name (will be used for all instances)"
                                      Required="true"
                                      RequiredError="Name is required" />
                    </MudItem>

                    <!-- Start Time -->
                    <MudItem xs="12" md="6">
                        <MudTimePicker Label="Start Time (same for all classes)" 
                                       @bind-Time="selectedTime" 
                                       Required="true" />
                    </MudItem>

                    <!-- Duration -->
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="dto.TrainingClassClassesDuration"
                                         Label="Duration (minutes)"
                                         Min="15"
                                         Required="true" />
                    </MudItem>

                    <!-- Planning Start & End -->
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Planning Start Date (first class)" 
                                       @bind-Date="planningStartDate" 
                                       Required="true"
                                       MinDate="DateTime.Today" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Planning End Date (last possible class)" 
                                       @bind-Date="planningEndDate" 
                                       Required="true"
                                       MinDate="@planningStartDate" />
                    </MudItem>

                    <!-- Days of Week -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Days of the Week</MudText>
                        <MudChipSet T="int" @bind-SelectedValues="selectedDays" SelectionMode="SelectionMode.MultiSelection" CheckMark="true" Variant="Variant.Filled" Color="Color.Primary">
                            @foreach (var day in Enum.GetValues<DayOfWeek>())
                            {
                                <MudChip Text="@day.ToString()" Value="@((int)day)" Color="Color.Primary" Variant="Variant.Text"/>
                            }
                        </MudChipSet>
                        @if (!selectedDays.Any())
                        {
                            <MudText Color="Color.Error" Class="mt-2">Select at least one day</MudText>
                        }
                    </MudItem>

                    <!-- Frequency -->
                    <MudItem xs="12" md="6">
                        <MudSelect T="int" Label="Frequency" @bind-Value="dto.TrainingClassTemplateFrequency" Required="true">
                            <MudSelectItem Value="1">Every week</MudSelectItem>
                            <MudSelectItem Value="2">Every 2nd week</MudSelectItem>
                            <MudSelectItem Value="3">Every 3rd week</MudSelectItem>
                            <MudSelectItem Value="4">Every 4th week</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <!-- Description -->
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Description (same for all)</MudText>
                        <MudHtmlEditor @bind-Content="dto.TrainingClassClassesDescription"
                                       Style="height: 300px;"
                                       Placeholder="Write a detailed description..." />
                    </MudItem>

                    <!-- Access Control -->
                    <MudItem xs="12">
                        <MudCheckBox T="bool" @bind-Value="allHaveAccess"
                                     Label="All members can enroll"
                                     Color="Color.Primary" />
                    </MudItem>

                    @if (!allHaveAccess)
                    {
                        <MudItem xs="12">
                            <MudSelect T="string"
                                       Label="Allowed Membership Groups"
                                       MultiSelection="true"
                                       MultiSelectionTextFunc="@GetGroupDisplayText"
                                       @bind-SelectedValues="selectedGroupGuids">
                                @foreach (var group in membershipGroups)
                                {
                                    <MudSelectItem Value="@group.MemberPaymentGroupGUID">
                                        @group.MemberPaymentGroupName (@group.MemberPaymentPrice:C)/month
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
                                Selected: @selectedGroupGuids.Count() group@(selectedGroupGuids.Count() == 1 ? "" : "s")
                            </MudText>
                        </MudItem>
                    }

                    <!-- Capacity -->
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="dto.TrainingClassClassesMax" Label="Max Participants" Min="1" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="dto.TrainingClassClassesMin" Label="Min Participants" Min="1" />
                    </MudItem>

                    <!-- Cancellation & Fine -->
                    <MudItem xs="12" md="4">
                        <MudNumericField @bind-Value="dto.TrainingClassClassesMaxCancellationTime"
                                         Label="Cancel allowed (min before)"
                                         Min="0" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudCheckBox T="bool" @bind-Value="autoCancelEnabled" Label="Auto-cancel if below min" />
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudCheckBox T="bool" @bind-Value="applyFine" Label="Fine if no-show" />
                    </MudItem>

                    <!-- Trainer -->
                    <MudItem xs="12">
                        <MudSelect T="string" Label="Trainer (Optional - same for all)" 
                                   @bind-Value="dto.TrainingClassTemplateTrainerGUID" 
                                   Clearable="true"
                                   Placeholder="None">
                            @foreach (var t in trainers)
                            {
                                <MudSelectItem Value="@t.MemberGUID">@t.TrainerName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <!-- Estimated number of classes -->
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Class="mt-4">
                            <strong>Estimated classes to be created:</strong> @estimatedCount
                        </MudAlert>
                    </MudItem>

                </MudGrid>

                <div class="d-flex justify-end mt-10">
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Success"
                               Size="Size.Large"
                               Disabled="@(!IsFormValid())"
                               Style="min-width: 280px;">
                        Create Recurring Classes
                    </MudButton>
                </div>
            </EditForm>
        </MudPaper>
    </div>
</div>

@code {
    private StaffTrainingClassAddMultiDTO dto = new() { TrainingClassTemplateFrequency = 1 };
    private List<StaffTrainingClassTypeDTO> classTypes = new();
    private List<StaffTrainingClassLocationDTO> locations = new();
    private List<MembershipsDTO> membershipGroups = new();
    private List<StaffTrainerDTO> trainers = new();

    // UI state
    private TimeSpan? selectedTime = TimeSpan.FromHours(18);
    private DateTime? planningStartDate = DateTime.Today.AddDays(1);
    private DateTime? planningEndDate = DateTime.Today.AddMonths(3);
    private IReadOnlyCollection<int> selectedDays = Array.Empty<int>(); 
    private bool allHaveAccess = true;
    private bool autoCancelEnabled = false;
    private bool applyFine = false;
    private IEnumerable<string> selectedGroupGuids = new HashSet<string>();

    private int estimatedCount => CalculateEstimatedClasses();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadClassTypes(),
            LoadLocations(),
            LoadMembershipGroups(),
            LoadTrainers()
        );
    }

    private async Task LoadClassTypes()
    {
        var resp = await StaffService.StaffGetClassTypesAsync(1, 200);
        classTypes = resp.types ?? new();
    }

    private async Task LoadLocations()
    {
        var resp = await StaffService.StaffGetClassLocationsAsync(1, 100);
        locations = resp.StaffTrainingClassLocations ?? new();
    }

    private async Task LoadMembershipGroups()
    {
        try
        {
            var resp = await MembershipService.GetMembershipListAsync();
            membershipGroups = resp.PaymentGroups ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load membership groups: " + ex.Message, Severity.Error);
        }
    }

    private async Task LoadTrainers()
    {
        try
        {
            var resp = await TrainingClassesService.GetTrainerListAsync();
            trainers = resp.Data ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to load trainers: " + ex.Message, Severity.Error);
        }
    }

    private bool IsFormValid()
    {
        return !string.IsNullOrWhiteSpace(dto.TrainingClassTypesGUID) &&
               !string.IsNullOrWhiteSpace(dto.TrainingClassLocationGUID) &&
               !string.IsNullOrWhiteSpace(dto.TrainingClassClassesName) &&
               selectedTime.HasValue &&
               planningStartDate.HasValue &&
               planningEndDate.HasValue &&
               selectedDays.Any() &&
               dto.TrainingClassTemplateFrequency > 0;
    }

    private int CalculateEstimatedClasses()
    {
        if (!planningStartDate.HasValue ||
            !planningEndDate.HasValue ||
            !selectedDays.Any() ||
            !selectedTime.HasValue ||
            dto.TrainingClassTemplateFrequency == 0)
            return 0;

        int count = 0;
        var current = planningStartDate.Value.Date;

        while (current <= planningEndDate.Value.Date)
        {
            if (selectedDays.Contains((int)current.DayOfWeek))
            {
                count++;
            }
            current = current.AddDays(7 * dto.TrainingClassTemplateFrequency);
        }

        return count;
    }

    private async Task SubmitClasses()
    {
        if (!IsFormValid())
        {
            Snackbar.Add("Please fill all required fields", Severity.Error);
            return;
        }

        dto.TrainingClassTemplateStartTime = TimeOnly.FromTimeSpan(selectedTime.Value);
        dto.TrainingClassTemplatePlanningStart = planningStartDate.Value.Date;
        dto.TrainingClassTemplatePlanningEnd = planningEndDate.Value.Date;

        // Store as comma-separated integers: "1,3,5" for Mon,Wed,Fri

        dto.TrainingClassTemplateDayOfWeek = string.Join(",",
            selectedDays
                .Select(d => d == (int)DayOfWeek.Sunday ? 7 : (int)d)  // Sunday → 7, others unchanged
                .OrderBy(x => x));


        dto.TrainingClassClassesAccess = allHaveAccess ? 0 : 1;
        dto.TrainingClassClassesAccessGUIDs = allHaveAccess
            ? Array.Empty<string>()
            : selectedGroupGuids.ToArray();

        dto.TrainingClassClassesAutomaticCancellation = autoCancelEnabled ? 1 : 0;
        dto.TrainingClassClassesFine = applyFine ? 1 : 0;

        // Console.WriteLine("Creating multiple classes:");
        // Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(dto,
        //     new System.Text.Json.JsonSerializerOptions { WriteIndented = true }));

        Console.WriteLine("Creating multiple classes:");
        Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(dto,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true }));

        StaffTrainingClassAddMultiResponseDTO result = await TrainingClassesService.StaffCreateMultipleClasses(dto);

        if (result.Success != true)
        {
            Snackbar.Add("Failed to create classes: " + result.Message, Severity.Error);
            return;
        }

        Snackbar.Add(result.Message, Severity.Success);
    }

    private string GetGroupDisplayText(List<string> guids)
    {
        if (guids == null || !guids.Any()) return "No groups selected";

        var names = guids.Select(g =>
        {
            var group = membershipGroups.FirstOrDefault(x => x.MemberPaymentGroupGUID == g);
            return group != null 
                ? $"{group.MemberPaymentGroupName} ({group.MemberPaymentPrice:C}/month)" 
                : g;
        }).ToList();

        return names.Count > 2 
            ? $"{names.Count} groups selected" 
            : string.Join(", ", names);
    }

}