@page "/classes/types"
@using BlazorAdminTemplate.Application.DTOs.Location
@using BlazorAdminTemplate.Application.DTOs.ClassTypes
@using BlazorAdminTemplate.Components.Classes
@inject IStaffManagementService StaffService
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>Class Types</PageTitle>

@* <MudText Typo="Typo.h4" GutterBottom="true">Training Class Types</MudText> *@

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           StartIcon="ti ti-plus"
           OnClick="OpenAddDialog"
           Class="mb-4">
    Add New Class Type
</MudButton>

<MudPaper Class="pa-4" Elevation="2">
    @if (loading)
    {
        <div class="d-flex justify-center">
            <MudProgressCircular Indeterminate="true" />
        </div>
        <MudText Align="Align.Center">Loading class types...</MudText>
    }
    else if (classTypes == null || !classTypes.Any())
    {
        <MudAlert Severity="Severity.Info">No class types found.</MudAlert>
    }
    else
    {
        <MudTable Items="@classTypes" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Max Participants</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Style="width:160px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name"><strong>@context.TrainingClassTypesName</strong></MudTd>
                <MudTd DataLabel="Location">@context.TrainingClassLocationName</MudTd>
                <MudTd DataLabel="Max">@context.TrainingClassTypesMax</MudTd>
                <MudTd DataLabel="Description">
                    @if (!string.IsNullOrWhiteSpace(context.TrainingClassTypesDescription))
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            @(new MarkupString(context.TrainingClassTypesDescription.Length > 100
                                                ? context.TrainingClassTypesDescription.Substring(0, 97) + "..."
                                                : context.TrainingClassTypesDescription))
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="font-style: italic;">No description</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                        <MudButton
                                   StartIcon="ti ti-edit"
                                   OnClick="@(() => EditType(context))">
                            Edit
                        </MudButton>
                        <MudButton Color="Color.Error"
                                   StartIcon="ti ti-trash"
                                   OnClick="@(() => DeleteType(context))">
                            Delete
                        </MudButton>
                    </MudButtonGroup>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <MudPagination Count="@totalPages"
                       BoundaryCount="2"
                       MiddleCount="5"
                       SelectedChanged="PageChanged"
                       Class="mt-4" />
    }
</MudPaper>

@code {
    private List<StaffTrainingClassTypeDTO> classTypes = new();
    private int currentPage = 1;
    private int pageSize = 15;
    private int totalPages = 1;
    private bool loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        StateHasChanged();

        try
        {
            var response = await StaffService.StaffGetClassTypesAsync(currentPage, pageSize);

            if (!string.IsNullOrEmpty(response.Message))
            {
                // Show API message only if it's an error
                if (response.Message.Contains("Error") || response.Message.Contains("error") || response.Message.Contains("failed"))
                {
                    Snackbar.Add(response.Message, Severity.Error);
                }
            }

            classTypes = response.types ?? new List<StaffTrainingClassTypeDTO>();
            totalPages = response.Pagination?.TotalPages ?? 1;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading class types: {ex.Message}", Severity.Error);
            classTypes = new();
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task PageChanged(int page)
    {
        currentPage = page;
        await LoadData();
    }

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters<EditClassTypeDialog>
        {
            { x => x.ClassType, new StaffTrainingClassTypeDTO() },
            { x => x.IsEditMode, false }
        };

        var dialog = await Dialog.ShowAsync<EditClassTypeDialog>("Add New Class Type", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data != null)
        {
            var message = result.Data.ToString();
            Snackbar.Add(message ?? "Class type added successfully!", Severity.Success);
            await LoadData();
        }
    }

    private async Task EditType(StaffTrainingClassTypeDTO type)
    {
        var parameters = new DialogParameters<EditClassTypeDialog>
        {
            { x => x.ClassType, new StaffTrainingClassTypeDTO(type) },
            { x => x.IsEditMode, true }
        };

        var dialog = await Dialog.ShowAsync<EditClassTypeDialog>("Edit Class Type", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data != null)
        {
            var message = result.Data.ToString();
            Snackbar.Add(message ?? "Class type updated successfully!", Severity.Success);
            await LoadData();
        }
    }

    private async Task DeleteType(StaffTrainingClassTypeDTO type)
    {
        bool? confirmed = await Dialog.ShowMessageBox(
            "Confirm Delete",
            $"Delete class type \"{type.TrainingClassTypesName}\"? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                var response = await StaffService.StaffDeleteClassTypeAsync(type.TrainingClassTypesGUID);
                
                if (!string.IsNullOrEmpty(response.Message))
                {
                    if (response.Message.Contains("Error") || response.Message.Contains("error") || response.Message.Contains("failed"))
                    {
                        Snackbar.Add(response.Message, Severity.Error);
                    }
                    else
                    {
                        Snackbar.Add(response.Message, Severity.Success);
                        await LoadData();
                    }
                }
                else
                {
                    Snackbar.Add("Class type deleted successfully", Severity.Success);
                    await LoadData();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting class type: {ex.Message}", Severity.Error);
            }
        }
    }
}