@page "/access-log"
@using BlazorAdminTemplate.Components.DoorAccess
@using MudBlazor
@inject HttpClient Http
@inject IDialogService DialogService

<PageTitle>Door Access Log</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h3" GutterBottom="true">Door Access Log</MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-6">View and filter recent door access events</MudText>

    <MudDataGrid T="AccessLogEntry"
                 Items="@_entries"
                 Dense="true"
                 Bordered="true"
                 Striped="true"
                 Hover="true"
                 Sortable="true"
                 Filterable="true"
                 QuickFilter="@_quickFilter"
                 Loading="@_loading">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Access Events</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="Search" 
                          Adornment="Adornment.Start" 
                          Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn T="AccessLogEntry" TProperty="DateTime" Property="x => x.Timestamp" Title="Date & Time" Sortable="true">
                <CellTemplate>
                    <MudText>@context.Item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                </CellTemplate>
            </PropertyColumn>
            <PropertyColumn T="AccessLogEntry" TProperty="string" Property="x => x.UserName" Title="User" />
            <PropertyColumn T="AccessLogEntry" TProperty="string" Property="x => x.DoorName" Title="Door" />
            <PropertyColumn T="AccessLogEntry" TProperty="string" Property="x => x.Status" Title="Status">
                <CellTemplate>
                    <MudChip Size="Size.Small" 
                             Color="@(context.Item.Status == "Granted" ? Color.Success : Color.Error)"
                             Variant="Variant.Filled">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </PropertyColumn>
            <TemplateColumn T="AccessLogEntry" Title="Actions">
                <CellTemplate>
                    <MudButton Size="Size.Small" 
                               Variant="Variant.Text" 
                               Color="Color.Primary"
                               OnClick="@(() => OpenDetailsDialog(context.Item))">
                        Details
                    </MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="AccessLogEntry" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<AccessLogEntry>? _entries;
    private bool _loading;
    private string? _searchString;

    // Quick filter for client-side if needed
    private Func<AccessLogEntry, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        return x.UserName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               x.DoorName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               x.Status.Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    };

    protected override async Task OnInitializedAsync()
    {
        // For demo: load placeholder data directly (no real API call)
        _entries = GeneratePlaceholderData(50);
        _loading = false;
    }

