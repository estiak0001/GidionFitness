    private void OpenDetailsDialog(AccessLogEntry entry)
    {
        var parameters = new DialogParameters<AccessDetailsDialog>
        {
            { x => x.Entry, entry }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

        DialogService.Show<AccessDetailsDialog>("Access Details", parameters, options);
    }

    private List<AccessLogEntry> GeneratePlaceholderData(int count)
    {
        var random = new Random();
        var users = new[] { "John Doe", "Jane Smith", "Mike Johnson", "Sarah Williams", "Tom Brown" };
        var doors = new[] { "Main Entrance", "Back Door", "Server Room", "Office Floor 2", "Garage Gate" };
        var statuses = new[] { "Granted", "Denied", "Granted", "Granted", "Denied" }; // More granted for realism

        var entries = new List<AccessLogEntry>();

        for (int i = 0; i < count; i++)
        {
            entries.Add(new AccessLogEntry
            {
                Id = i + 1,
                Timestamp = DateTime.Now.AddHours(-random.Next(1, 720)).AddMinutes(-random.Next(0, 60)),
                UserName = users[random.Next(users.Length)],
                DoorName = doors[random.Next(doors.Length)],
                Status = statuses[random.Next(statuses.Length)],
                Reason = statuses[random.Next(statuses.Length)] == "Denied" ? "Invalid Credential" : null
            });
        }

        return entries.OrderByDescending(x => x.Timestamp).ToList();
    }

    // Helper for sorting in server example
    // private object GetPropertyValue(AccessLogEntry item, string propertyName)
    // {
    //     return item.GetType().GetProperty(propertyName)?.GetValue(item, null) ?? "";
    // }

    public class AccessLogEntry
    {
        public int Id { get; set; }
        public DateTime Timestamp { get; set; }
        public string UserName { get; set; } = "";
        public string DoorName { get; set; } = "";
        public string Status { get; set; } = "";
        public string? Reason { get; set; }
        public string? CardId { get; set; } = "1234-5678-9012";
        public string? PhotoUrl { get; set; } // Could be used for image if real
    }
}