<MudText Typo="Typo.h5" GutterBottom="true">Notification Preferences</MudText>
<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Email Notifications</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="3">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.subtitle1">Account Updates</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Important account changes</MudText>
                        </div>
                        <MudSwitch @bind-Value="EmailAccountUpdates" Color="Color.Primary" Disabled />
                    </div>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.subtitle1">Training Reminders</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Upcoming session reminders</MudText>
                        </div>
                        <MudSwitch @bind-Value="EmailTrainingReminders" Color="Color.Primary" Disabled />
                    </div>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.subtitle1">Marketing Emails</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Promotions and updates</MudText>
                        </div>
                        <MudSwitch @bind-Value="EmailMarketing" Color="Color.Primary" Disabled />
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Push Notifications</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudStack Spacing="3">
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.subtitle1">Mobile Push</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Notifications on mobile app</MudText>
                        </div>
                        <MudSwitch @bind-Value="PushMobile" Color="Color.Primary" Disabled />
                    </div>
                    <div class="d-flex justify-space-between align-center">
                        <div>
                            <MudText Typo="Typo.subtitle1">SMS Alerts</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Critical alerts via SMS</MudText>
                        </div>
                        <MudSwitch @bind-Value="PushSMS" Color="Color.Primary" Disabled />
                    </div>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public bool EmailAccountUpdates { get; set; } = true;
    [Parameter] public bool EmailTrainingReminders { get; set; } = true;
    [Parameter] public bool EmailMarketing { get; set; } = false;
    [Parameter] public bool PushMobile { get; set; } = true;
    [Parameter] public bool PushSMS { get; set; } = false;
}