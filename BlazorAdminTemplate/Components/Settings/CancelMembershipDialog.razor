@using BlazorAdminTemplate.Application.DTOs.Memberships
@using MudBlazor
@using BlazorAdminTemplate.Application.DTOs.Payment
@using BlazorAdminTemplate.Domain.Enums
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-3" Color="Color.Warning" />
            Cancel Membership
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (isCheckingEligibility)
        {
            <div class="d-flex justify-content-center py-4">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else if (!canCancelMembership)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @membershipCancellationPolicy?.Message
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                You are about to <strong>cancel</strong> active membership.
                This action cannot be undone and will immediately end all membership benefits.
            </MudAlert>

            <MudDatePicker @bind-Value="cancelRequest.CancellationDate"
                          Label="Effective Date"
                          Variant="Variant.Outlined"
                          Lines="3"
                          Required="true"
                          Class="mb-4" />
            
            <MudTextField @bind-Value="cancelRequest.CancellationReason"
                          Label="Cancellation Reason"
                          Variant="Variant.Outlined"
                          Lines="3"
                          Required="true"
                          Class="mb-4" />
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@ErrorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        @if (!isCheckingEligibility && canCancelMembership)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       OnClick="ConfirmCancellation"
                       Disabled="@(string.IsNullOrEmpty(cancelRequest.CancellationReason) || 
                                   cancelRequest.CancellationDate == default || 
                                   IsProcessing)">
                @if (IsProcessing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Confirm Cancellation
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int MemberId { get; set; }
    [Parameter] public int ActiveMembershipId { get; set; }

    private bool isCheckingEligibility = true;
    private bool canCancelMembership = false;
    private MemberCancelMembershipCheckResponseDTO? membershipCancellationPolicy = null;
    
    private CancelMembershipReason SelectedReason { get; set; }
    private MemberCancelMembershipDTO cancelRequest = new MemberCancelMembershipDTO();
    private string Notes { get; set; } = string.Empty;
    private string? ErrorMessage { get; set; }
    private bool IsProcessing { get; set; }

    [Inject] private IMemberMembershipService MemberMembershipService { get; set; } = default!;
    [Inject] private IMemberPaymentService MemberPaymentService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await CheckMembershipCancellationEligibility();
    }

    private async Task CheckMembershipCancellationEligibility()
    {
        isCheckingEligibility = true;
        ErrorMessage = null;
        
        try
        {
            membershipCancellationPolicy = await MemberMembershipService.GetMemberMembershipCancelPolicy();
            
            if (membershipCancellationPolicy != null)
            {
                canCancelMembership = membershipCancellationPolicy.CanCancel && 
                                        membershipCancellationPolicy.CanCancelNow == true;
            }
            else
            {
                canCancelMembership = false;
                ErrorMessage = "Failed to retrieve cancellation policy information.";
            }
        }
        catch (Exception ex)
        {
            canCancelMembership = false;
            ErrorMessage = "An error occurred while checking cancellation eligibility. Please try again.";
            Console.WriteLine($"Error checking membership cancellation eligibility: {ex.Message}");
        }
        finally
        {
            isCheckingEligibility = false;
        }
    }

    private async Task ConfirmCancellation()
    {
        if (IsProcessing) return;
        
        IsProcessing = true;
        ErrorMessage = null;
        
        try
        {
            var result = await MemberMembershipService.MemberMembershipCancel(new MemberCancelMembershipDTO
            {
                CancellationDate = cancelRequest.CancellationDate,
                CancellationReason = cancelRequest.CancellationReason
            });
            
            if (!string.IsNullOrEmpty(result.Message))
            {
                Snackbar.Add($"Cancellation: {result.Message}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                ErrorMessage = "Failed to cancel membership.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine($"Error cancelling membership: {ex.Message}");
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private void CloseDialog() => MudDialog.Close(DialogResult.Cancel());
}