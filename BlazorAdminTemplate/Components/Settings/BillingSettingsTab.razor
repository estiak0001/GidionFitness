@using BlazorAdminTemplate.Application.DTOs.Payment
@using BlazorAdminTemplate.Components.PaginationComponents
@using BlazorAdminTemplate.Domain.Enums
@inject IMemberCardService MemberCardService
@inject IMemberMembershipService MemberMembershipService
@inject IMemberPaymentService MemberPaymentService
@inject IPaymentService PaymentService
@inject IJSRuntime JS
@inject IDialogService DialogService

<MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged" />

@if (isMobile)
{
    <!-- Mobile Layout -->
    <div class="text-center">
        <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4" Align="Align.Center">Billing & Payments</MudText>

        <MudStack Spacing="3" AlignItems="AlignItems.Center">
            <!-- Current Membership Card (Mobile First) -->
            <MudCard Elevation="2" Style="width: 100%; max-width: 400px;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Align="Align.Center">Current Membership</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="text-center">
                    @if (isLoading)
                    {
                        <MudProgressCircular Indeterminate="true" />
                    }
                    else if (membershipInfo != null && membershipInfo.PaymentInfo != null)
                    {
                        <MudStack Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Color="Color.Primary">@membershipInfo.PaymentInfo.MemberPaymentGroupName</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@membershipInfo.PaymentInfo.MemberPaymentGroupDescription</MudText>
                            <MudText Typo="Typo.h5" Color="Color.Success">@membershipInfo.PaymentInfo.MemberPaymentPrice.ToString("C")</MudText>
                            @if (membershipInfo.PaymentInfo.MemberPaymentPausePrice.HasValue)
                            {
                                <MudText Typo="Typo.body2">Pause Price: @membershipInfo.PaymentInfo.MemberPaymentPausePrice?.ToString("C")</MudText>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No membership information found.</MudText>
                    }
                </MudCardContent>
            </MudCard>

            <!-- Payment Methods Card -->
            <MudCard Elevation="2" Style="width: 100%; max-width: 400px;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Align="Align.Center">Payment Methods</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Color="Color.Primary"
                                       Disabled="@isLoading"
                                       OnClick="AddCreditCardAsync"
                                       Title="Add Payment Method" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (isLoading)
                    {
                        <div class="text-center">
                            <MudProgressCircular Indeterminate="true" />
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
                    }
                    else if (cardInfo != null && cardInfo.PaymentCards != null && cardInfo.PaymentCards.Any())
                    {
                        <MudStack Spacing="2">
                            @foreach (var card in cardInfo.PaymentCards)
                            {
                                <div class="pa-3" style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                                    <div class="d-flex flex-column align-center text-center">
                                        <div class="d-flex align-center mb-2">
                                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Class="mr-2" Color="Color.Primary" />
                                            <MudText Typo="Typo.subtitle1">@card.MemberCardMaskedPan</MudText>
                                        </div>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                                            @GetCardType(card.MemberCardCardType ?? -1) • Expires @card.MemberCardCardExpiryDate
                                        </MudText>
                                        <div class="d-flex align-center gap-2">
                                            @if (card.MemberCardStatus == 1)
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Default</MudChip>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => DeleteCard(card.MemberCardGUID))"
                                                           Title="Remove Card" />
                                        </div>
                                    </div>
                                </div>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Large" Class="mud-text-secondary mb-2" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">No payment methods found.</MudText>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AddCreditCardAsync"
                                       Class="mt-2">
                                Add Payment Method
                            </MudButton>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudStack>

        <!-- Payment History Section (Mobile) -->
        <div class="mt-6">
            <MudText Typo="Typo.h6" GutterBottom="true" Class="mb-4" Align="Align.Center">Betalings historik</MudText>

            @if (isLoading)
            {
                <div class="text-center">
                    <MudProgressCircular Indeterminate="true" />
                </div>
            }
            else if (payments != null && payments.Payments.Count > 0)
            {
                <!-- Mobile Payment Cards -->
                <MudStack Spacing="3" AlignItems="AlignItems.Center">
                    @foreach (var payment in payments.Payments)
                    {
                        <MudCard Elevation="2" Style="width: 100%; max-width: 400px;">
                            <MudCardContent Class="text-center">
                                <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                    <div class="d-flex align-center justify-space-between w-100">
                                        <MudText Typo="Typo.subtitle1">@(!string.IsNullOrEmpty(payment.MemberPaymentDataOrderNumber) ? payment.MemberPaymentDataOrderNumber : "Ukendt")</MudText>
                                        <MudChip T="string"
                                                 Color="@(payment.MemberPaymentDataDirection == 1 ? Color.Error : payment.MemberPaymentDataDirection == 2 ? Color.Success : Color.Default)"
                                                 Variant="Variant.Filled"
                                                 Size="Size.Small">
                                            @(payment.MemberPaymentDataDirection == 1 ? "Betaling"
                                                                            : payment.MemberPaymentDataDirection == 2 ? "Refundering"
                                                                            : "Ukendt")
                            </MudChip>
                        </div>

                                    <MudText Typo="Typo.h6"
                                             Color="@(payment.MemberPaymentDataDirection == 1 ? Color.Error : payment.MemberPaymentDataDirection == 2 ? Color.Success : Color.Default)">
                            @if (payment.MemberPaymentDataDirection == 1)
                                        {
                                            @($"-{payment.MemberPaymentDataAmount:C}")
                                        }
                                        else if (payment.MemberPaymentDataDirection == 2)
                                        {
                                            @($"+{payment.MemberPaymentDataAmount:C}")
                                        }
                                        else
                                        {
                                            @payment.MemberPaymentDataAmount.ToString("C")
                                        }
                                    </MudText>

                                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                        @{
                                            var formattedDate = DateTime.TryParse(payment.MemberPaymentDataDate, out var dt)
                                            ? dt.ToString("dd-MM-yyyy HH:mm")
                                            : payment.MemberPaymentDataDate ?? "Ukendt";
                                        }
                                    @formattedDate
                                </MudText>

                                <MudChip T="string"
                                         Color="@(payment.MemberPaymentDataStatus == 0 ? Color.Success : payment.MemberPaymentDataStatus == 1 ? Color.Warning : Color.Default)"
                                         Variant="Variant.Filled"
                                         Size="Size.Small">
                                    @(payment.MemberPaymentDataStatus == 0 ? "Betalt"
                                                                : payment.MemberPaymentDataStatus == 1 ? "Nylig lavet"
                                                                : "Ukendt")
                        </MudChip>
                    </MudStack>
                </MudCardContent>
            </MudCard>
                        }
                </MudStack>

                <!-- Mobile Pagination -->
                <div class="d-flex justify-center mt-4">
                    <div class="d-flex align-center" style="gap: 1rem;">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                       Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Disabled="@(payments.Pagination.HasPreviousPage == false)"
                                       OnClick="@(() => ChangePage(payments.Pagination.CurrentPage - 1))"
                                       Title="Forrige side" />

                        <MudText Typo="Typo.body2" Class="mx-3">
                            Side @payments.Pagination.CurrentPage af @payments.Pagination.TotalPages
                        </MudText>

                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                       Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Disabled="@(payments.Pagination.HasNextPage == false)"
                                       OnClick="@(() => ChangePage(payments.Pagination.CurrentPage + 1))"
                                       Title="Næste side" />
                    </div>
                </div>
            }
            else if (payments != null && payments.Payments.Count == 0)
            {
                <div class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Class="mud-text-secondary mb-2" />
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Ingen betalings historik</MudText>
                </div>
            }
        </div>
    </div>
}
else
{
    <!-- Desktop Layout (Original) -->
    <MudText Typo="Typo.h5" GutterBottom="true">Billing & Payments</MudText>
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Payment Methods</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Disabled="@isLoading" OnClick="AddCreditCardAsync">
                            Add Payment Method
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="3">
                        @if (isLoading)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
                        }
                        else if (cardInfo != null && cardInfo.PaymentCards != null)
                        {
                            @foreach (var card in cardInfo.PaymentCards)
                            {
                                <div class="d-flex justify-content-between align-content-center pa-3" style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                                    <div class="d-flex align-content-center">
                                        <MudIcon Icon="@Icons.Material.Filled.CreditCard" Class="mr-3" Color="Color.Primary" />
                                        <div>
                                            <MudText Typo="Typo.subtitle1">@card.MemberCardMaskedPan</MudText>
                                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                                @GetCardType(card.MemberCardCardType ?? -1) • Expires @card.MemberCardCardExpiryDate
                                            </MudText>
                                        </div>
                                    </div>
                                    <div class="d-flex align-content-center">
                                        @if (card.MemberCardStatus == 1)
                                        {
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="mr-2">Default</MudChip>
                                        }
                                        <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                                            <MudMenuItem Icon="@Icons.Material.Filled.Edit">Edit</MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => DeleteCard(card.MemberCardGUID))">Remove</MudMenuItem>
                                        </MudMenu>
                                    </div>
                                </div>
                            }
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Current Membership</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="3">
                        @if (isLoading)
                        {
                            <MudProgressCircular Indeterminate="true" />
                        }
                        else if (membershipInfo != null && membershipInfo.PaymentInfo != null)
                        {
                            <div class="mb-2">
                                <MudText Typo="Typo.h5" Color="Color.Primary">@membershipInfo.PaymentInfo.MemberPaymentGroupName</MudText>
                                <MudText Typo="Typo.body2">@membershipInfo.PaymentInfo.MemberPaymentGroupDescription</MudText>
                                <MudText Typo="Typo.body2">Price: @membershipInfo.PaymentInfo.MemberPaymentPrice.ToString("C")</MudText>
                                <MudText Typo="Typo.body2">Pause Price: @membershipInfo.PaymentInfo.MemberPaymentPausePrice?.ToString("C")</MudText>
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">No membership information found.</MudText>
                        }
                    </MudStack>
                </MudCardContent>
                <MudCardActions Class="gap-3">
                    <MudButton @onclick="OpenChangeMemebershipDialogAsync" Variant="Variant.Filled" Color="Color.Primary">Change</MudButton>
                    <MudButton @onclick="OpenPauseMemebershipDialogAsync" Variant="Variant.Filled" Color="Color.Primary">Pause</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               OnClick="@(() => OpenCancelMembershipDialogAsync(0, 0))">
                        Cancel Membership
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-6">Betalings historik</MudText>
    @if (isLoading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (payments != null && payments.Payments.Count > 0)
    {
        @if (currentView == ViewType.Table)
        {
            <PaginatedList TItem="MemberPaymentDTO"
                           Items="payments.Payments"
                           Pagination="payments.Pagination"
                           OnPageChanged="LoadPayments">
                <HeaderTemplate>
                    <MudTh>Order #</MudTh>
                    <MudTh>Måde</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderTemplate>
                <RowTemplate>
                    <MudTd>@context.MemberPaymentDataOrderNumber</MudTd>
                    <MudTd>
                        @if (context.MemberPaymentDataDirection == 1)
                        {
                            <MudChip T="string" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small">Betaling</MudChip>
                        }
                        else if (context.MemberPaymentDataDirection == 2)
                        {
                            <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Refundering</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small">Ukendt</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.MemberPaymentDataDirection == 1)
                        {
                            <MudText Color="Color.Error">@($"-{context.MemberPaymentDataAmount:C}")</MudText>
                        }
                        else if (context.MemberPaymentDataDirection == 2)
                        {
                            <MudText Color="Color.Success">@($"+{context.MemberPaymentDataAmount:C}")</MudText>
                        }
                        else
                        {
                            <MudText Color="Color.Default">@context.MemberPaymentDataAmount.ToString("C")</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        @{
                            var formattedDate = DateTime.TryParse(context.MemberPaymentDataDate, out var dt)
                            ? dt.ToString("dd-MM-yyyy HH:mm")
                            : context.MemberPaymentDataDate;
                        }
                        @formattedDate
                    </MudTd>
                    <MudTd>
                        @if (context.MemberPaymentDataStatus == 0)
                        {
                            <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">Betalt</MudChip>
                        }
                        else if (context.MemberPaymentDataStatus == 1)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">Nylig lavet</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Filled" Size="Size.Small">Ukendt</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </PaginatedList>
        }
        else if (currentView == ViewType.Cards)
        {
            <MudGrid>
                @foreach (var payment in payments.Payments)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="mb-3">
                            <MudCardContent>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <MudText Typo="Typo.h6">@(!string.IsNullOrEmpty(payment.MemberPaymentDataOrderNumber) ? payment.MemberPaymentDataOrderNumber : "Ukendt")</MudText>
                                    <MudChip T="string"
                                             Color="@(payment.MemberPaymentDataDirection == 1 ? Color.Error : payment.MemberPaymentDataDirection == 2 ? Color.Success : Color.Default)"
                                             Variant="Variant.Filled"
                                             Rounded="true"
                                             Size="Size.Small">
                                        @(payment.MemberPaymentDataDirection == 1 ? "Betaling"
                                                                : payment.MemberPaymentDataDirection == 2 ? "Refundering"
                                                                : "Ukendt")
                    </MudChip>
                </div>
                <MudText Typo="Typo.body2"
                         Color="@(payment.MemberPaymentDataDirection == 1 ? Color.Error : payment.MemberPaymentDataDirection == 2 ? Color.Success : Color.Default)">
                    @if (payment.MemberPaymentDataDirection == 1)
                                    {
                                        @($"-{payment.MemberPaymentDataAmount:C}")
                                    }
                                    else if (payment.MemberPaymentDataDirection == 2)
                                    {
                                        @($"+{payment.MemberPaymentDataAmount:C}")
                                    }
                                    else
                                    {
                                        @payment.MemberPaymentDataAmount.ToString("C")
                                    }
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Default">
                                    @{
                                        var formattedDate = DateTime.TryParse(payment.MemberPaymentDataDate, out var dt)
                                        ? dt.ToString("dd-MM-yyyy HH:mm")
                                        : payment.MemberPaymentDataDate ?? "Ukendt";
                                    }
                                @formattedDate
                            </MudText>
                            <MudDivider Class="my-2" />
                            <MudChip T="string"
                                     Color="@(payment.MemberPaymentDataStatus == 0 ? Color.Success : payment.MemberPaymentDataStatus == 1 ? Color.Warning : Color.Default)"
                                     Variant="Variant.Filled"
                                     Rounded="true"
                                     Size="Size.Small">
                                @(payment.MemberPaymentDataStatus == 0 ? "Betalt"
                                                    : payment.MemberPaymentDataStatus == 1 ? "Nylig lavet"
                                                    : "Ukendt")
                </MudChip>
            </MudCardContent>
        </MudCard>
    </MudItem>
        }
            </MudGrid>
            <div class="d-flex justify-content-center my-3">
                <MudButton Disabled="@(payments.Pagination.HasPreviousPage == false)" OnClick="@(() => ChangePage(payments.Pagination.CurrentPage - 1))">Previous</MudButton>
                <span class="mx-2">Page @payments.Pagination.CurrentPage of @payments.Pagination.TotalPages</span>
                <MudButton Disabled="@(payments.Pagination.HasNextPage == false)" OnClick="@(() => ChangePage(payments.Pagination.CurrentPage + 1))">Next</MudButton>
            </div>
        }
    }
    else if (payments != null && payments.Payments.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="mt-4">Ingen betalings historik</MudText>
    }
}

@code {
    private MemberPaymentCardInfoResponseDTO? cardInfo;
    private MemberPaymentMembershipInfoResponseDTO? membershipInfo;
    private MemberPaymentListReponseDTO? payments;
    private ViewType currentView = ViewType.Table;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private int currentPage = 1;
    private bool isMobile = false; // NEW: Mobile state

    private void OnBreakpointChanged(Breakpoint breakpoint)
    {
        // For payment history table/cards
        currentView = breakpoint <= Breakpoint.Sm ? ViewType.Cards : ViewType.Table;
        // For overall mobile layout
        isMobile = breakpoint <= Breakpoint.Sm;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cardInfo = await MemberCardService.GetPaymentCardInfoAsync();
            membershipInfo = await MemberMembershipService.GetMembershipInfo();
            await LoadPayments(currentPage);

            if (cardInfo == null || cardInfo.PaymentCards == null || cardInfo.PaymentCards.Count == 0)
            {
                errorMessage = "No payment methods found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading payment methods: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetCardType(int type)
    {
        return type switch
        {
            1 => "Visa",
            2 => "MasterCard",
            3 => "Dankort",
            10 => "Unknown/Other",
            _ => "Card"
        };
    }

    private async Task LoadPayments(int page)
    {
        isLoading = true;
        payments = await MemberPaymentService.GetMemberPaymentsAsync(page);
        currentPage = page;
        isLoading = false;
        StateHasChanged();
    }

    private async Task ChangePage(int page)
    {
        await LoadPayments(page);
    }

    private async Task DeleteCard(string cardGuid)
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            await MemberCardService.DeletePaymentCardAsync(cardGuid);

            cardInfo = await MemberCardService.GetPaymentCardInfoAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting card: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task AddCreditCardAsync()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {

            var response = await MemberCardService.AddNewPaymentCardAsync();

            if (!string.IsNullOrEmpty(response?.PaymentWindowLink))
            {
                await JS.InvokeVoidAsync("window.open", response.PaymentWindowLink, "_blank");
            }

            await LoadPayments(currentPage);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding card: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // private Task OpenCancelMemebershipDialogAsync()
    // {
    //     var options = new DialogOptions { CloseOnEscapeKey = true };

    //     return DialogService.ShowAsync<CancelMembershipDialog>("Are you sure?", options);   
    // }

    private async Task OpenCancelMembershipDialogAsync(int memberId, int membershipId)
    {
        var parameters = new DialogParameters<CancelMembershipDialog>
        {
            { x => x.MemberId, memberId },
            { x => x.ActiveMembershipId, membershipId }
        };

        var dialog = await DialogService.ShowAsync<CancelMembershipDialog>("Cancel Membership", parameters,
            new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;

        // if (!result.Canceled)
        // {
        //     await LoadMembers(); Example: reload the grid
        //     Snackbar.Add("Cancellation processed.", Severity.Success);
        // }
    }

    private Task OpenChangeMemebershipDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        return DialogService.ShowAsync<ChangeMembershipDialog>("Are you sure?", options);
    }

    private Task OpenPauseMemebershipDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        return DialogService.ShowAsync<PauseMembershipDialog>("Are you sure?", options);
    }
}