@using Microsoft.AspNetCore.Components
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 60vh; overflow: auto;">
            @((MarkupString)Html)
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Close">Luk</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Html { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = "Kontrakt";
    private void Close() => MudDialog.Close();
}