@using BlazorAdminTemplate.Application.DTOs.Payment
@using BlazorAdminTemplate.Application.Interfaces
@inject IPaymentGroupService PaymentGroupService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CardMembership" Class="mr-2" />
            @(IsEditMode ? "Rediger medlemskab" : "Opret medlemskab")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <div class="d-flex justify-center py-4">
                <MudProgressCircular Indeterminate="true" />
            </div>
        }
        else
        {
            <MudForm @ref="form" @bind-IsValid="@isValid">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.MemberPaymentGroupName"
                                      Label="Navn"
                                      Required="true"
                                      Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.MemberPaymentGroupDescription"
                                      Label="Beskrivelse"
                                      Lines="3"
                                      Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="model.MemberPaymentPrice"
                                         Label="Pris (årlig)"
                                         Required="true"
                                         Adornment="Adornment.End"
                                         AdornmentText="kr."
                                         Min="0"
                                         Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="model.MemberPaymentPausePrice"
                                         Label="Pause pris (månedlig)"
                                         Required="true"
                                         Adornment="Adornment.End"
                                         AdornmentText="kr/md"
                                         Min="0"
                                         Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="model.MemberPaymentValidFrom"
                                       Label="Gyldig fra"
                                       Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker @bind-Date="model.MemberPaymentValidTo"
                                       Label="Gyldig til"
                                       Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="string" 
                                   @bind-Value="model.PaymentProviderDataGUID"
                                   Label="Betalingsudbyder"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Disabled="@(!paymentProviders.Any())"
                                   Clearable="true"
                                   ToStringFunc="@(guid => string.IsNullOrEmpty(guid) ? "Vælg betalingsudbyder" : (paymentProviders.FirstOrDefault(p => p.PaymentProviderDataGUID == guid)?.PaymentProviderName ?? "Ukendt"))">
                            @if (paymentProviders.Any())
                            {
                                @foreach (var provider in paymentProviders)
                                {
                                    <MudSelectItem T="string" Value="@provider.PaymentProviderDataGUID">
                                        @provider.PaymentProviderName
                                    </MudSelectItem>
                                }
                            }
                            else
                            {
                                <MudSelectItem T="string" Value="@string.Empty" Disabled="true">
                                    Ingen betalingsudbydere tilgængelige
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="string" 
                                   @bind-Value="model.MemberGroupDefaultGroupsGUID"
                                   Label="Standard gruppe"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Disabled="@(!defaultGroups.Any())"
                                   Clearable="true"
                                   ToStringFunc="@(guid => string.IsNullOrEmpty(guid) ? "Vælg standard gruppe" : (defaultGroups.FirstOrDefault(g => g.MemberGroupDefaultGroupsGUID == guid)?.MemberGroupDefaultGroupsName ?? "Ukendt"))">
                            @if (defaultGroups.Any())
                            {
                                @foreach (var group in defaultGroups)
                                {
                                    <MudSelectItem T="string" Value="@group.MemberGroupDefaultGroupsGUID">
                                        @group.MemberGroupDefaultGroupsName
                                    </MudSelectItem>
                                }
                            }
                            else
                            {
                                <MudSelectItem T="string" Value="@string.Empty" Disabled="true">
                                    Ingen standardgrupper tilgængelige
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="enableChecked"
                                   Label="Aktiv"
                                   Color="Color.Success" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="defaultChecked"
                                   Label="Standard medlemskab"
                                   Color="Color.Primary" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudSwitch @bind-Value="vatChecked"
                                   Label="Inkl. moms"
                                   Color="Color.Info" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuller</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="Submit"
                   Disabled="@(!isValid || isSaving)">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEditMode ? "Gem" : "Opret")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public StaffPaymentGroupDTO? PaymentGroup { get; set; }

    private MudForm form = default!;
    private bool isValid;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool IsEditMode => PaymentGroup != null;

    private PaymentGroupModel model = new();
    private List<PaymentProviderDTO> paymentProviders = new();
    private List<MemberGroupDefaultDTO> defaultGroups = new();

    // Backing fields for switches
    private bool _enableChecked;
    private bool _defaultChecked;
    private bool _vatChecked;

    // Helper properties to convert int to bool for switches
    private bool enableChecked
    {
        get => _enableChecked;
        set
        {
            if (_enableChecked != value)
            {
                _enableChecked = value;
                model.MemberPaymentEnable = value ? 1 : 0;
                Console.WriteLine($"Enable switch changed: {value}, model value: {model.MemberPaymentEnable}");
                StateHasChanged();
            }
        }
    }

    private bool defaultChecked
    {
        get => _defaultChecked;
        set
        {
            if (_defaultChecked != value)
            {
                _defaultChecked = value;
                model.MemberPaymentDefault = value ? 1 : 0;
                Console.WriteLine($"Default switch changed: {value}, model value: {model.MemberPaymentDefault}");
                StateHasChanged();
            }
        }
    }

    private bool vatChecked
    {
        get => _vatChecked;
        set
        {
            if (_vatChecked != value)
            {
                _vatChecked = value;
                model.MemberPaymentPriceVAT = value ? 1 : 0;
                Console.WriteLine($"VAT switch changed: {value}, model value: {model.MemberPaymentPriceVAT}");
                StateHasChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Load dropdown data first
        await LoadDropdownData();
        
        if (IsEditMode && PaymentGroup != null)
        {
            model.MemberPaymentGroupGUID = PaymentGroup.MemberPaymentGroupGUID;
            model.MemberPaymentGroupName = PaymentGroup.MemberPaymentGroupName;
            model.MemberPaymentGroupDescription = PaymentGroup.MemberPaymentGroupDescription;
            model.MemberPaymentValidFrom = PaymentGroup.MemberPaymentValidFrom;
            model.MemberPaymentValidTo = PaymentGroup.MemberPaymentValidTo;
            model.MemberPaymentPrice = PaymentGroup.MemberPaymentPrice;
            model.MemberPaymentPriceVAT = PaymentGroup.MemberPaymentPriceVAT;
            model.MemberPaymentEnable = PaymentGroup.MemberPaymentEnable;
            model.MemberPaymentDefault = PaymentGroup.MemberPaymentDefault;
            model.PaymentProviderDataGUID = PaymentGroup.PaymentProviderDataGUID;
            model.MemberPaymentPausePrice = PaymentGroup.MemberPaymentPausePrice;
            model.MemberGroupDefaultGroupsGUID = PaymentGroup.MemberGroupDefaultGroupsGUID;
            
            // Set switch backing fields
            _enableChecked = PaymentGroup.MemberPaymentEnable == 1;
            _defaultChecked = PaymentGroup.MemberPaymentDefault == 1;
            _vatChecked = PaymentGroup.MemberPaymentPriceVAT == 1;
            
            Console.WriteLine($"Backing fields set - Enable: {_enableChecked}, Default: {_defaultChecked}, VAT: {_vatChecked}");
            StateHasChanged();
        }
        else
        {
            // Initialize default values for create mode
            _enableChecked = true;
            model.MemberPaymentEnable = 1;
            Console.WriteLine("Create mode - Enable switch initialized to true");
        }

        isLoading = false;
    }

    private async Task LoadDropdownData()
    {
        try
        {
            // Load payment providers
            try
            {
                var providersResponse = await PaymentGroupService.GetPaymentProvidersAsync();
                paymentProviders = providersResponse?.PaymentProviders ?? new List<PaymentProviderDTO>();
                Console.WriteLine($"Loaded {paymentProviders.Count} payment providers");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading payment providers: {ex.Message}");
                Snackbar.Add($"Fejl ved indlæsning af betalingsudbydere: {ex.Message}", Severity.Error);
            }

            // Load default groups
            try
            {
                var groupsResponse = await PaymentGroupService.GetDefaultGroupsAsync();
                defaultGroups = groupsResponse?.MemberGroupDefaultGroups ?? new List<MemberGroupDefaultDTO>();
                Console.WriteLine($"Loaded {defaultGroups.Count} default groups");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading default groups: {ex.Message}");
                Snackbar.Add($"Fejl ved indlæsning af standardgrupper: {ex.Message}", Severity.Error);
            }

            // Set defaults if available
            if (!IsEditMode)
            {
                if (paymentProviders.Any())
                    model.PaymentProviderDataGUID = paymentProviders.First().PaymentProviderDataGUID;
                if (defaultGroups.Any())
                    model.MemberGroupDefaultGroupsGUID = defaultGroups.First().MemberGroupDefaultGroupsGUID;
                
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fejl ved indlæsning: {ex.Message}", Severity.Error);
        }
    }

    private async Task Submit()
    {
        await form.Validate();
        if (!isValid) return;

        try
        {
            isSaving = true;

            if (IsEditMode)
            {
                var updateDto = new StaffPaymentGroupUpdateDTO
                {
                    MemberPaymentGroupGUID = model.MemberPaymentGroupGUID,
                    MemberPaymentGroupName = model.MemberPaymentGroupName,
                    MemberPaymentGroupDescription = model.MemberPaymentGroupDescription,
                    MemberPaymentValidFrom = model.MemberPaymentValidFrom,
                    MemberPaymentValidTo = model.MemberPaymentValidTo,
                    MemberPaymentPrice = model.MemberPaymentPrice,
                    MemberPaymentPriceVAT = model.MemberPaymentPriceVAT == 1,
                    MemberPaymentEnable = model.MemberPaymentEnable == 1,
                    MemberPaymentDefault = model.MemberPaymentDefault == 1,
                    PaymentProviderDataGUID = model.PaymentProviderDataGUID,
                    MemberPaymentPausePrice = model.MemberPaymentPausePrice,
                    MemberGroupDefaultGroupsGUID = model.MemberGroupDefaultGroupsGUID
                };

                await PaymentGroupService.UpdatePaymentGroupAsync(updateDto);
                Snackbar.Add("Medlemskab opdateret", Severity.Success);
            }
            else
            {
                var createDto = new StaffPaymentGroupCreateDTO
                {
                    MemberPaymentGroupName = model.MemberPaymentGroupName,
                    MemberPaymentGroupDescription = model.MemberPaymentGroupDescription,
                    MemberPaymentValidFrom = model.MemberPaymentValidFrom,
                    MemberPaymentValidTo = model.MemberPaymentValidTo,
                    MemberPaymentPrice = model.MemberPaymentPrice,
                    MemberPaymentPriceVAT = model.MemberPaymentPriceVAT == 1,
                    MemberPaymentEnable = model.MemberPaymentEnable == 1,
                    MemberPaymentDefault = model.MemberPaymentDefault == 1,
                    PaymentProviderDataGUID = model.PaymentProviderDataGUID,
                    MemberPaymentPausePrice = model.MemberPaymentPausePrice,
                    MemberGroupDefaultGroupsGUID = model.MemberGroupDefaultGroupsGUID
                };

                await PaymentGroupService.CreatePaymentGroupAsync(createDto);
                Snackbar.Add("Medlemskab oprettet", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fejl: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private class PaymentGroupModel
    {
        public string MemberPaymentGroupGUID { get; set; } = string.Empty;
        public string MemberPaymentGroupName { get; set; } = string.Empty;
        public string MemberPaymentGroupDescription { get; set; } = string.Empty;
        public DateTime? MemberPaymentValidFrom { get; set; }
        public DateTime? MemberPaymentValidTo { get; set; }
        public decimal MemberPaymentPrice { get; set; }
        public int MemberPaymentPriceVAT { get; set; }
        public int MemberPaymentEnable { get; set; }
        public int MemberPaymentDefault { get; set; }
        public string PaymentProviderDataGUID { get; set; } = string.Empty;
        public decimal? MemberPaymentPausePrice { get; set; }
        public string MemberGroupDefaultGroupsGUID { get; set; } = string.Empty;
    }
}
