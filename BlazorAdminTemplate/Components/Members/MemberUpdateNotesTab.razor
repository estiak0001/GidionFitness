@using BlazorAdminTemplate.Application.DTOs.Notes
@using BlazorAdminTemplate.Application.DTOs.Pagination
@inject IStaffManagementService StaffManagementService
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject IJSRuntime JS

<MudPaper Class="pa-6" Elevation="2">
    <MudStack Spacing="4">
        <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudItem>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Note" Class="mr-3" />
                    Notes (@(tableData?.TotalItems ?? 0))
                </MudText>
            </MudItem>
            <MudItem>
                <MudTextField @bind-Value="searchTerm"
                              Immediate="true"
                              DebounceInterval="500"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Placeholder="Search notes..."
                              Clearable="true"
                              OnClearButtonClick="ClearSearch"
                              Class="mr-4"
                              Style="max-width: 300px;" />
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddNewNote">
                    New Note
                </MudButton>
            </MudItem>
        </MudGrid>


            <MudTable @ref="table"
                      T="MemberNote"
                      ServerData="ServerReload"
                      Loading="@isLoading"
                      Hover="true"
                      Striped="true"
                      Bordered="true"
                      Dense="true"
                      Elevation="2"
                      Class="mt-4">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<MemberNote, object>(x => x.MemberNotesDate)">
                            Date
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>Content</MudTh>
                    <MudTh Style="width:150px;">Visibility</MudTh>
                    <MudTh Style="width:150px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.MemberNotesDate.ToString("dd MMM yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Content">
                        <div class="note-preview cursor-pointer"
                             @onclick="() => ViewNote(context)"
                             style="max-height: 60px; overflow: hidden;">
                            @((MarkupString)TruncateHtml(context.MemberNotesText, 120))
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Visibility">
                        <MudChip T="string"
                                 Color="@(context.MemberNotesVissible == 1 ? Color.Success : Color.Warning)"
                                 Variant="Variant.Filled"
                                 Size="Size.Small">
                            @(context.MemberNotesVissible == 0 ? "Visible" : "Hidden")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButtonGroup Size="Size.Small">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Color="Color.Info"
                                           OnClick="() => ViewNote(context)"
                                           Title="View" />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Warning"
                                           OnClick="() => EditNote(context)"
                                           Title="Edit" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           OnClick="() => DeleteNote(context)"
                                           Title="Delete" />
                        </MudButtonGroup>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
                </PagerContent>
                <NoRecordsContent>
                    <MudAlert Severity="Severity.Info" Class="mx-4 my-4">
                        No notes for this member.
                    </MudAlert>
                </NoRecordsContent>
            </MudTable>
       
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string MemberGuid { get; set; } = string.Empty;
    [Parameter] public EventCallback OnNotesRefreshed { get; set; }

    private MudTable<MemberNote> table = new();
    private TableData<MemberNote> tableData = new();
    private bool isLoading = false;
    private string searchTerm = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await table.ReloadServerData();
        }
    }

    private async Task<TableData<MemberNote>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        isLoading = true;
        try
        {
            var request = new StaffMemberNotesRequestDTO
            {
                MemberGuid = MemberGuid,
                Page = state.Page + 1,
                PageSize = state.PageSize,
                Search = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim()
            };

            var response = await StaffManagementService.StaffGetMemberNotesAsync(request);

            tableData = new TableData<MemberNote>
            {
                TotalItems = response.Pagination.TotalRecords,
                Items = response.Notes
            };

            return tableData;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load notes: {ex.Message}", Severity.Error);
            return new TableData<MemberNote> { TotalItems = 0, Items = new List<MemberNote>() };
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        await table.ReloadServerData();
    }

    private async Task AddNewNote()
    {
        var parameters = new DialogParameters
        {
            ["MemberGuid"] = MemberGuid,
            ["NoteGuid"] = string.Empty,
            ["Mode"] = "Add"
        };

        var dialog = await Dialog.ShowAsync<StaffMemberNoteEditDialog>("New Note", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await RefreshNotes();
        }
    }

    private async Task EditNote(MemberNote note)
    {
        var parameters = new DialogParameters
        {
            ["MemberGuid"] = MemberGuid,
            ["NoteGuid"] = note.MemberNotesGuid,
            ["Mode"] = "Edit"
        };

        var dialog = await Dialog.ShowAsync<StaffMemberNoteEditDialog>("Edit Note", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await RefreshNotes();
        }
    }

    private async Task ViewNote(MemberNote note)
    {
        var parameters = new DialogParameters
        {
            ["MemberGuid"] = MemberGuid,
            ["NoteGuid"] = note.MemberNotesGuid,
            ["Mode"] = "View"
        };

        var dialog = await Dialog.ShowAsync<StaffMemberNoteEditDialog>("View Note", parameters);
        await dialog.Result; // Just wait for close
    }

    private async Task DeleteNote(MemberNote note)
    {
        var confirmed = await Dialog.ShowMessageBox(
            "Delete Note",
            $"Are you sure you want to delete this note from {note.MemberNotesDate:dd MMM yyyy HH:mm}?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed == true)
        {
            try
            {
                var result = await StaffManagementService.StaffDeleteMemberNoteAsync(note.MemberNotesGuid);

                if (result.Success)
                {
                    Snackbar.Add(result.Message ?? "Note deleted successfully!", Severity.Success);
                    await RefreshNotes();
                }
                else
                {
                    Snackbar.Add(result.Message ?? "Delete failed.", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task RefreshNotes()
    {
        await table.ReloadServerData();
        await OnNotesRefreshed.InvokeAsync();
    }

    private string TruncateHtml(string html, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(html)) return "";
        var text = System.Text.RegularExpressions.Regex.Replace(html, "<.*?>", " ");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ").Trim();
        return text.Length > maxLength ? text.Substring(0, maxLength) + "..." : text;
    }
}