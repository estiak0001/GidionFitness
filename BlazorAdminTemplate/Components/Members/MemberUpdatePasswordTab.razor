@using BlazorAdminTemplate.Application.DTOs.Members
@using BlazorAdminTemplate.Application.Interfaces
@using FluentValidation
@inject IStaffManagementService staffManagementService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudPaper Class="pa-8" Elevation="3">
    <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-3" />
        Skift adgangskode
    </MudText>
    <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Class="mb-6">
        Udfyld kun "Ny adgangskode" for at ændre adgangskoden. Lad feltet stå tomt for at springe over.
    </MudAlert>
    <EditForm Model="@request" OnValidSubmit="SavePassword">
        <FluentValidationValidator @ref="fluentValidator" />
        <MudGrid Spacing="4">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="request.NewPassword"
                              Label="Ny adgangskode"
                              Variant="Variant.Outlined"
                              InputType="@(showNew? InputType.Text: InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(showNew? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => showNew = !showNew)" />
            </MudItem>
        </MudGrid>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Class="mt-5 mb-4">
                @ErrorMessage
            </MudAlert>
        }
        <div class="d-flex justify-end gap-4 mt-8">
            <MudButton OnClick="ClearForm" Disabled="@isSubmitting">
                Ryd felt
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@isSubmitting"
                       StartIcon="@Icons.Material.Filled.Save">
                @if (isSubmitting)
                {
                    <MudProgressCircular Class="ms-2" Size="Size.Small" Indeterminate="true" />
                }
                Gem ny adgangskode
            </MudButton>
        </div>
    </EditForm>
</MudPaper>

@code {
    [Parameter] public string MemberGuid { get; set; } = string.Empty;

    private StaffChangeMemberPasswordDto request = new();
    private FluentValidationValidator fluentValidator = new();
    private bool showNew = false;
    private bool isSubmitting = false;
    private string ErrorMessage = string.Empty;

    protected override void OnParametersSet()
    {
        request.MemberGuid = MemberGuid;
        ClearFormFieldsOnly();
    }

    private async Task SavePassword()
    {
        ErrorMessage = string.Empty;
        isSubmitting = true;

        try
        {
            // Hvis NewPassword er tom, spring over ændring
            if (string.IsNullOrWhiteSpace(request.NewPassword))
            {
                Snackbar.Add("Ingen ændring foretaget – ny adgangskode var tom.", MudBlazor.Severity.Info);
                ClearFormFieldsOnly();
                return;
            }

            var response = await staffManagementService.StaffChangeMemberPasswordAsync(request);

            if (!string.IsNullOrEmpty(response?.Message))
            {
                // Antager at tom Message betyder succes (baseret på din service-implementation)
                Snackbar.Add("Adgangskode blev ændret succesfuldt!", MudBlazor.Severity.Success);
                ClearFormFieldsOnly();
            }
            else
            {
                ErrorMessage = response.Message ?? "Adgangskoden blev ikke ændret. Prøv igen.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Fejl: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ClearForm()
    {
        ClearFormFieldsOnly();
    }

    private void ClearFormFieldsOnly()
    {
        request.NewPassword = string.Empty;
        showNew = false;
        ErrorMessage = string.Empty;
    }
}