@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string MemberGuid { get; set; } = string.Empty;
    [Parameter] public EventCallback OnMemberUpdated { get; set; }

    private MudForm form = new();
    private StaffUpdateMemberRequestDTO updateRequest = new();
    private StaffUpdateMemberResponseDTO? updateResponse;
    private readonly UpdateMemberRequestValidator validator = new(); 

    private bool isLoading = true;
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;

    // Password visibility toggles
    private bool showCurrentPassword = false;
    private bool showNewPassword = false;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(MemberGuid))
        {
            errorMessage = "Medlem ID mangler.";
            isLoading = false;
            return;
        }

        await LoadMemberData();
    }

    private async Task LoadMemberData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;
            StateHasChanged();

           

            var memberDetails = await MemberService.GetSpecificMemberAsync(MemberGuid);

            if (memberDetails == null || string.IsNullOrEmpty(memberDetails.MemberGUID))
            {
                errorMessage = "Kunne ikke indlæse medlemsdata.";
                return;
            }

            // Map the response to the update request
            updateRequest = new StaffUpdateMemberRequestDTO
            {
                MemberGuid = memberDetails.MemberGUID,
                OrganisationMainGuid = memberDetails.OrganisationMainGuid,
                OrganisationSubGuid = memberDetails.OrganisationSubGuid,
                MemberPaymentGroupGuid = memberDetails.MemberPaymentGroupGuid,
                MemberFirstName = memberDetails.MemberFirstName,
                MemberLastName = memberDetails.MemberLastName,
                MemberAddress = memberDetails.MemberAddress,
                MemberCity = memberDetails.MemberCity,
                MemberZipCode = memberDetails.MemberZipCode,
                MemberBirthday = memberDetails.MemberBirthday,
                MemberSex = memberDetails.MemberSex,
                MemberCPR = memberDetails.MemberCPR,
                MemberPhonePrivate = memberDetails.MemberPhonePrivate,
                MemberPhoneWork = memberDetails.MemberPhoneWork,
                MemberEmail = memberDetails.MemberEmail,
                MemberJobTitle = memberDetails.MemberJobTitle,
                MemberLanguageGUID = string.Empty, 
                MemberHealthInsurance = null, 
                NewPassword = string.Empty,
                CurrentPassword = string.Empty
            };

            
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading member data: {ex.Message}");
            errorMessage = $"Fejl ved indlæsning: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveChanges()
    {
        try
        {
            isSubmitting = true;
            errorMessage = string.Empty;
            StateHasChanged();

            
            await form.Validate();

            if (!form.IsValid)
            {
                errorMessage = "Ret venligst fejlene i formularen.";
                return;
            }

           
            updateResponse = await MemberService.UpdateMemberAsync(updateRequest);

            if (updateResponse == null || string.IsNullOrEmpty(updateResponse.MemberGUID))
            {
                errorMessage = "Der opstod en fejl ved opdatering af medlemmet.";
                return;
            }

            

            Snackbar.Add($"Medlem {updateResponse.MemberName} blev opdateret succesfuldt!", MudBlazor.Severity.Success);

            // Notify parent component
            if (OnMemberUpdated.HasDelegate)
            {
                await OnMemberUpdated.InvokeAsync();
            }

            // Close dialog after a short delay to show the success state
            await Task.Delay(1500);
            MudDialog.Close(DialogResult.Ok(updateResponse));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating member: {ex.Message}");
            errorMessage = $"Fejl ved opdatering: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Cancel());
    }
}