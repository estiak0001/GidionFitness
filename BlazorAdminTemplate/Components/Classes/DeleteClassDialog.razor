@using BlazorAdminTemplate.Application.DTOs.Classes
@using MudBlazor
@inject ITrainingClassesService TrainingClassesService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Color="Color.Error">
            <MudIcon Icon="Icons.Material.Filled.DeleteForever" Class="mr-3" />
            Permanently Delete Class
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <strong>This action is permanent and cannot be recovered.</strong>
        </MudAlert>
        <MudText>
            Are you sure you want to <strong>permanently delete</strong> the class:<br />
            <strong>@Class.TrainingClassClassesName</strong>?
        </MudText>
        <MudText Class="mt-3">
            All enrollments and records will be lost forever.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Back</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" StartIcon="Icons.Material.Filled.Delete" OnClick="Confirm">
            Delete Forever
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public StaffTrainingClassGetResponseDTO Class { get; set; } = default!;

    private async Task Confirm()
    {
        var result = await TrainingClassesService.StaffDeleteClass(Class.TrainingClassClassesGUID);
        
        if (result.Success)
        {
            Snackbar.Add(result.Message, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
            MudDialog.Close(DialogResult.Cancel());
        }
    } 
    private void Cancel() => MudDialog.Cancel();
}